---
---
<footer class="w-full bg-canvas border-t border-hairline py-16 md:py-20 mt-auto" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Footer</h2>
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-10 md:gap-6 mb-12">
      <!-- Column 1: Branding & Tagline -->
      <div class="space-y-4">
        <a href="/" class="flex items-center space-x-2 select-none group">
          <svg class="w-5 h-5 text-primary transition-transform duration-200 group-hover:scale-105" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M20 12L4 21V3L20 12Z" fill="currentColor" />
          </svg>
          <span class="text-lg font-bold tracking-tight text-primary">ytomp3</span>
        </a>
        <p class="text-xs text-body leading-relaxed max-w-[240px]">
          Free, premium high-performance web media utility for extraction and conversion of YouTube content.
        </p>
        <p class="text-[11px] font-mono text-mute">
          Designed for speed, simplicity, and user security.
        </p>
      </div>

      <!-- Column 2: Product Links -->
      <div class="space-y-4">
        <h4 class="text-xs font-mono uppercase tracking-wider text-primary font-semibold">Features</h4>
        <ul class="space-y-2">
          <li>
            <a href="/" class="text-xs text-body hover:text-primary hover:underline transition-colors">YouTube to MP3</a>
          </li>
          <li>
            <a href="/" class="text-xs text-body hover:text-primary hover:underline transition-colors">YouTube to MP4</a>
          </li>
          <li>
            <a href="/faq" class="text-xs text-body hover:text-primary hover:underline transition-colors">FAQ / Help Center</a>
          </li>
          <li>
            <a href="/add-on" class="text-xs text-body hover:text-primary hover:underline transition-colors">Extension & Add-on</a>
          </li>
        </ul>
      </div>

      <!-- Column 3: Legal Policy Links -->
      <div class="space-y-4">
        <h4 class="text-xs font-mono uppercase tracking-wider text-primary font-semibold">Legal Policy</h4>
        <ul class="space-y-2">
          <li>
            <a href="/terms-of-use" class="text-xs text-body hover:text-primary hover:underline transition-colors">Terms of Use</a>
          </li>
          <li>
            <a href="/privacy-policy" class="text-xs text-body hover:text-primary hover:underline transition-colors">Privacy Policy</a>
          </li>
          <li>
            <a href="/dmca" class="text-xs text-body hover:text-primary hover:underline transition-colors">DMCA / Copyright claims</a>
          </li>
        </ul>
      </div>

      <!-- Column 4: Contact/Support Channels -->
      <div class="space-y-4">
        <h4 class="text-xs font-mono uppercase tracking-wider text-primary font-semibold">Contact Support</h4>
        <ul class="space-y-2">
          <li>
            <a href="/contact" class="text-xs text-body hover:text-primary hover:underline transition-colors">Contact Form</a>
          </li>
          <li class="text-xs text-body font-mono select-all">
            support@ytomp3.in
          </li>
          <li class="pt-2">
            <span class="inline-flex items-center space-x-1.5 px-2 py-0.5 rounded-sm bg-success/10 text-[10px] font-mono text-success border border-success/20">
              <span class="w-1.5 h-1.5 bg-success rounded-full animate-pulse"></span>
              <span>All Systems Operational</span>
            </span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Divider and copyright row -->
    <div class="pt-8 border-t border-hairline flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-[11px] font-mono text-mute text-center sm:text-left">
        &copy; {new Date().getFullYear()} ytomp3.in. Not affiliated with Google LLC, YouTube or Alphabet Inc.
      </p>
      <div class="flex space-x-4">
        <span class="text-[10px] font-mono text-mute bg-canvas-soft-2 px-2 py-1 rounded border border-hairline">HTTPS Secure</span>
        <span class="text-[10px] font-mono text-mute bg-canvas-soft-2 px-2 py-1 rounded border border-hairline">No Malware</span>
      </div>
    </div>
  </div>
</footer>
