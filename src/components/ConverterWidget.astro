---
---
<div class="w-full max-w-[580px] bg-canvas border border-hairline rounded-lg shadow-level-4 p-6 md:p-8" id="converter-card">
  <!-- Tabs (MP3 / MP4) -->
  <div class="flex p-1 bg-canvas-soft-2 rounded-pill-sm border border-hairline mb-6" role="tablist">
    <button 
      type="button" 
      class="flex-1 py-2 text-sm font-medium rounded-pill-sm transition-all duration-200 cursor-pointer bg-canvas text-primary shadow-level-2"
      id="tab-mp3"
      role="tab"
      aria-selected="true"
    >
      MP3 (Audio)
    </button>
    <button 
      type="button" 
      class="flex-1 py-2 text-sm font-medium rounded-pill-sm transition-all duration-200 cursor-pointer text-body hover:text-primary"
      id="tab-mp4"
      role="tab"
      aria-selected="false"
    >
      MP4 (Video)
    </button>
  </div>

  <!-- STATE: IDLE -->
  <div id="state-idle" class="space-y-5">
    <div class="space-y-2">
      <label for="youtube-url" class="text-xs font-mono uppercase tracking-wider text-body">Paste YouTube Link</label>
      <div class="relative">
        <input 
          id="youtube-url" 
          type="url" 
          placeholder="youtube.com/watch?v=..." 
          class="w-full h-12 bg-canvas text-ink border border-hairline-strong/40 rounded-sm px-4 pr-10 text-sm focus:outline-none focus:border-primary transition-colors placeholder:text-mute focus:ring-1 focus:ring-primary"
          required
          autofocus
        />
        <svg class="absolute right-3 top-3.5 w-5 h-5 text-mute" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
        </svg>
      </div>
    </div>

    <!-- Quality Selection -->
    <div class="space-y-2">
      <label for="quality-select" class="text-xs font-mono uppercase tracking-wider text-body">Select Quality</label>
      <div class="relative">
        <select 
          id="quality-select" 
          class="w-full h-12 bg-canvas text-ink border border-hairline-strong/40 rounded-sm px-4 text-sm focus:outline-none focus:border-primary transition-colors appearance-none cursor-pointer focus:ring-1 focus:ring-primary"
        >
          <!-- MP3 Options (Default) -->
          <option value="320">MP3 — 320 kbps (Ultra High Quality)</option>
          <option value="256">MP3 — 256 kbps (High Quality)</option>
          <option value="192" selected>MP3 — 192 kbps (Standard Quality)</option>
          <option value="128">MP3 — 128 kbps (Econ Quality)</option>
        </select>
        <svg class="absolute right-3 top-4 w-4 h-4 text-mute pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </div>
    </div>

    <button 
      type="button" 
      id="btn-convert"
      class="w-full h-12 bg-primary hover:bg-opacity-90 text-on-primary font-medium rounded-pill text-sm transition-all duration-200 cursor-pointer shadow-level-3 select-none flex items-center justify-center space-x-2"
    >
      <span>Convert Link</span>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
      </svg>
    </button>
  </div>

  <!-- STATE: CONVERTING -->
  <div id="state-converting" class="hidden space-y-6 py-4">
    <!-- Spinner and status -->
    <div class="flex items-center space-x-4">
      <div class="w-10 h-10 rounded-full border-[3px] border-hairline border-t-primary animate-spin" id="converter-spinner"></div>
      <div class="space-y-0.5">
        <h4 class="text-sm font-semibold text-primary" id="status-title">Processing YouTube video</h4>
        <p class="text-xs text-mute" id="status-sub">Connecting to stream server...</p>
      </div>
    </div>

    <!-- Progress bar -->
    <div class="space-y-2">
      <div class="w-full h-1.5 bg-canvas-soft-2 rounded-full overflow-hidden border border-hairline">
        <div class="h-full bg-primary transition-all duration-300 ease-out" id="progress-bar" style="width: 0%"></div>
      </div>
      <div class="flex justify-between text-[11px] font-mono text-mute">
        <span id="progress-percent">0%</span>
        <span id="progress-eta">ETA: Calculating...</span>
      </div>
    </div>
  </div>

  <!-- STATE: DONE -->
  <div id="state-done" class="hidden space-y-6">
    <!-- Video Preview Card -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center space-y-4 sm:space-y-0 sm:space-x-4 p-4 bg-canvas-soft rounded-md border border-hairline">
      <!-- Thumbnail with mock image loader/placeholder -->
      <div class="relative w-full sm:w-[120px] aspect-video bg-canvas-soft-2 rounded-sm overflow-hidden flex-shrink-0 border border-hairline flex items-center justify-center">
        <img id="done-thumb" src="" alt="Video thumbnail" class="w-full h-full object-cover hidden" />
        <!-- Placeholder music note or video icon -->
        <div id="done-thumb-placeholder" class="text-mute flex flex-col items-center justify-center">
          <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
          </svg>
        </div>
      </div>
      <div class="space-y-1 min-w-0 flex-1">
        <h4 class="text-sm font-semibold text-primary truncate" id="done-title">Sample YouTube Video Title</h4>
        <p class="text-xs text-body" id="done-duration">Duration: --:--</p>
        <p class="text-xs font-mono text-mute" id="done-info">Format: MP3 • 192kbps • -- MB</p>
      </div>
    </div>

    <!-- Actions -->
    <div class="flex flex-col sm:flex-row gap-3">
      <a 
        id="btn-download" 
        href="#" 
        download
        class="flex-1 h-12 bg-primary hover:bg-opacity-90 text-on-primary font-medium rounded-pill text-sm transition-all duration-200 cursor-pointer shadow-level-3 select-none flex items-center justify-center space-x-2"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        <span>Download File</span>
      </a>
      <button 
        type="button" 
        id="btn-convert-another"
        class="flex-1 h-12 bg-canvas hover:bg-canvas-soft border border-hairline text-primary font-medium rounded-pill text-sm transition-all duration-200 cursor-pointer shadow-level-2 select-none"
      >
        Convert Another
      </button>
    </div>
  </div>

  <!-- STATE: ERROR -->
  <div id="state-error" class="hidden space-y-5 text-center py-4">
    <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-error-soft text-error mb-2">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
      </svg>
    </div>
    <div class="space-y-1">
      <h4 class="text-sm font-semibold text-error" id="error-title">Conversion Failed</h4>
      <p class="text-xs text-body" id="error-message">The YouTube link you entered is invalid or inaccessible.</p>
    </div>
    <button 
      type="button" 
      id="btn-error-retry"
      class="w-full h-12 bg-primary hover:bg-opacity-90 text-on-primary font-medium rounded-pill text-sm transition-all duration-200 cursor-pointer shadow-level-3"
    >
      Try Again
    </button>
  </div>
</div>

<script>
  // UI selectors
  const tabMp3 = document.getElementById('tab-mp3');
  const tabMp4 = document.getElementById('tab-mp4');
  const qualitySelect = document.getElementById('quality-select') as HTMLSelectElement;
  
  const stateIdle = document.getElementById('state-idle');
  const stateConverting = document.getElementById('state-converting');
  const stateDone = document.getElementById('state-done');
  const stateError = document.getElementById('state-error');

  const inputUrl = document.getElementById('youtube-url') as HTMLInputElement;
  const btnConvert = document.getElementById('btn-convert');
  const btnConvertAnother = document.getElementById('btn-convert-another');
  const btnErrorRetry = document.getElementById('btn-error-retry');
  const btnDownload = document.getElementById('btn-download') as HTMLAnchorElement;

  const progressBar = document.getElementById('progress-bar');
  const progressPercent = document.getElementById('progress-percent');
  const progressEta = document.getElementById('progress-eta');
  const statusTitle = document.getElementById('status-title');
  const statusSub = document.getElementById('status-sub');

  const doneThumb = document.getElementById('done-thumb') as HTMLImageElement;
  const doneThumbPlaceholder = document.getElementById('done-thumb-placeholder');
  const doneTitle = document.getElementById('done-title');
  const doneDuration = document.getElementById('done-duration');
  const doneInfo = document.getElementById('done-info');
  const errorMessage = document.getElementById('error-message');

  let currentFormat = 'mp3'; // 'mp3' or 'mp4'

  // Pre-fill URL from query parameter if present
  window.addEventListener('DOMContentLoaded', () => {
    const params = new URLSearchParams(window.location.search);
    const urlParam = params.get('url');
    if (urlParam && inputUrl) {
      inputUrl.value = decodeURIComponent(urlParam);
    }
  });

  // Toggle format tabs
  tabMp3?.addEventListener('click', () => {
    if (currentFormat === 'mp3') return;
    currentFormat = 'mp3';
    
    // UI update tabs
    tabMp3.classList.add('bg-canvas', 'text-primary', 'shadow-level-2');
    tabMp3.classList.remove('text-body', 'hover:text-primary');
    tabMp4?.classList.remove('bg-canvas', 'text-primary', 'shadow-level-2');
    tabMp4?.classList.add('text-body', 'hover:text-primary');
    
    // Update Quality Dropdown options
    if (qualitySelect) {
      qualitySelect.innerHTML = `
        <option value="320">MP3 — 320 kbps (Ultra High Quality)</option>
        <option value="256">MP3 — 256 kbps (High Quality)</option>
        <option value="192" selected>MP3 — 192 kbps (Standard Quality)</option>
        <option value="128">MP3 — 128 kbps (Econ Quality)</option>
      `;
    }
  });

  tabMp4?.addEventListener('click', () => {
    if (currentFormat === 'mp4') return;
    currentFormat = 'mp4';
    
    // UI update tabs
    tabMp4.classList.add('bg-canvas', 'text-primary', 'shadow-level-2');
    tabMp4.classList.remove('text-body', 'hover:text-primary');
    tabMp3?.classList.remove('bg-canvas', 'text-primary', 'shadow-level-2');
    tabMp3?.classList.add('text-body', 'hover:text-primary');
    
    // Update Quality Dropdown options
    if (qualitySelect) {
      qualitySelect.innerHTML = `
        <option value="1080">MP4 — 1080p (Full HD Video)</option>
        <option value="720" selected>MP4 — 720p (HD Video)</option>
        <option value="480">MP4 — 480p (Medium Quality)</option>
        <option value="360">MP4 — 360p (Low Quality)</option>
      `;
    }
  });

  // State transitions
  function showState(state: string) {
    stateIdle?.classList.add('hidden');
    stateConverting?.classList.add('hidden');
    stateDone?.classList.add('hidden');
    stateError?.classList.add('hidden');

    if (state === 'idle') stateIdle?.classList.remove('hidden');
    else if (state === 'converting') stateConverting?.classList.remove('hidden');
    else if (state === 'done') stateDone?.classList.remove('hidden');
    else if (state === 'error') stateError?.classList.remove('hidden');
  }

  // Parse Youtube Video ID
  function getYouTubeID(url: string) {
    const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
    const match = url.match(regExp);
    return (match && match[2].length === 11) ? match[2] : null;
  }

  // Conversion process
  btnConvert?.addEventListener('click', async () => {
    const url = inputUrl?.value.trim();
    if (!url) {
      if (inputUrl) inputUrl.reportValidity();
      return;
    }

    const videoId = getYouTubeID(url);
    
    // If not a valid youtube url
    if (!url.includes('youtube.com') && !url.includes('youtu.be') && !url.includes('y2u.be')) {
      if (errorMessage) {
        errorMessage.innerText = "Please enter a valid YouTube video URL. We currently only support YouTube links.";
      }
      showState('error');
      return;
    }

    // Go to converting state
    showState('converting');
    
    // Reset progress bar
    if (progressBar) progressBar.style.width = '0%';
    if (progressPercent) progressPercent.innerText = '0%';
    if (progressEta) progressEta.innerText = 'Connecting...';
    if (statusTitle) statusTitle.innerText = "Initializing conversion job";
    if (statusSub) statusSub.innerText = "Connecting to conversion server...";

    const selectedQuality = qualitySelect?.value || '192';

    try {
      // Initiate conversion job
      const response = await fetch(`/api/convert?url=${encodeURIComponent(url)}&format=${currentFormat}&quality=${selectedQuality}`);

      if (!response.ok) {
        const errData = await response.json();
        throw new Error(errData.error || 'Failed to initialize conversion');
      }

      const convertData = await response.json();
      const videoInfo = convertData.info;

      // Update UI title with video title
      if (statusTitle && videoInfo) {
        statusTitle.innerText = videoInfo.title;
      }

      if (convertData.status === 'completed') {
        // Instant cache hit!
        updateDoneState(videoInfo, convertData.downloadUrl, selectedQuality);
        showState('done');
        return;
      }

      // Processing - start polling
      const jobId = convertData.jobId;
      pollJobStatus(jobId, videoInfo, selectedQuality);

    } catch (err: any) {
      console.error(err);
      if (errorMessage) {
        errorMessage.innerText = err.message || 'An error occurred during video extraction.';
      }
      showState('error');
    }
  });

  function updateDoneState(videoInfo: any, downloadUrl: string, selectedQuality: string) {
    if (doneTitle) doneTitle.innerText = videoInfo.title;
    if (doneDuration) doneDuration.innerText = `Duration: ${formatSeconds(videoInfo.durationSeconds)}`;
    
    const isAudio = currentFormat === 'mp3';
    let sizeMB = 0;
    let qualityLabel = '';
    
    if (isAudio) {
      sizeMB = (videoInfo.durationSeconds * Number(selectedQuality)) / 8000;
      qualityLabel = `${selectedQuality}kbps`;
    } else {
      if (videoInfo.sizes && videoInfo.sizes[selectedQuality]) {
        sizeMB = videoInfo.sizes[selectedQuality];
      } else {
        const mins = videoInfo.durationSeconds / 60;
        const sizePerMin: Record<string, number> = { '1080': 15.0, '720': 8.0, '480': 4.5, '360': 2.5 };
        sizeMB = mins * (sizePerMin[selectedQuality] || 8.0);
      }
      qualityLabel = `${selectedQuality}p`;
    }

    if (doneInfo) {
      doneInfo.innerText = `Format: ${currentFormat.toUpperCase()} • ${qualityLabel} • ~${sizeMB.toFixed(1)} MB`;
    }

    if (doneThumb) {
      doneThumb.src = videoInfo.thumbnail;
      doneThumb.classList.remove('hidden');
      doneThumbPlaceholder?.classList.add('hidden');
    }

    if (btnDownload) {
      btnDownload.href = downloadUrl;
    }
  }

  function formatSeconds(seconds: number) {
    if (!seconds || isNaN(seconds) || seconds < 0) return '--:--';
    const hrs = Math.floor(seconds / 3600);
    const mins = Math.floor((seconds % 3600) / 60);
    const secs = seconds % 60;
    
    if (hrs > 0) {
      return `${hrs.toString().padStart(2, '0')}:${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
    }
    return `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
  }

  function pollJobStatus(jobId: string, videoInfo: any, selectedQuality: string) {
    const pollInterval = setInterval(async () => {
      try {
        const res = await fetch(`/api/job-status?jobId=${jobId}`);
        if (!res.ok) throw new Error('Status check failed');

        const statusData = await res.json();

        if (statusData.status === 'completed') {
          clearInterval(pollInterval);
          if (progressBar) progressBar.style.width = '100%';
          if (progressPercent) progressPercent.innerText = '100%';
          if (progressEta) progressEta.innerText = 'Completed!';
          
          updateDoneState(videoInfo, statusData.downloadUrl, selectedQuality);
          setTimeout(() => {
            showState('done');
          }, 300);
        } else if (statusData.status === 'failed') {
          clearInterval(pollInterval);
          if (errorMessage) {
            errorMessage.innerText = statusData.error || 'Conversion failed.';
          }
          showState('error');
        } else {
          // Status is processing (active or queued)
          const progress = statusData.progress || 0;
          if (progressBar) progressBar.style.width = `${progress}%`;
          if (progressPercent) progressPercent.innerText = `${progress}%`;
          
          if (statusSub) {
            if (progress < 10) {
              statusSub.innerText = "Queued in worker...";
              if (progressEta) progressEta.innerText = "Waiting...";
            } else if (progress < 80) {
              statusSub.innerText = "Downloading media stream(s)...";
              if (progressEta) progressEta.innerText = "Downloading...";
            } else {
              statusSub.innerText = currentFormat === 'mp3' ? "Transcoding to MP3..." : "Muxing audio & video tracks...";
              if (progressEta) progressEta.innerText = "Processing...";
            }
          }
        }
      } catch (err) {
        console.error('Error polling status:', err);
        // Keep polling on network glitches
      }
    }, 1500);
  }

  // Reset to idle
  btnConvertAnother?.addEventListener('click', () => {
    if (inputUrl) inputUrl.value = '';
    if (progressBar) progressBar.style.width = '0%';
    showState('idle');
  });

  btnErrorRetry?.addEventListener('click', () => {
    showState('idle');
  });
</script>
