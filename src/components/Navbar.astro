---
const currentPath = Astro.url.pathname;
---
<header class="sticky top-0 z-50 w-full h-16 bg-canvas border-b border-hairline backdrop-blur-md bg-opacity-80">
  <div class="max-w-[1200px] h-full mx-auto px-6 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center space-x-2 select-none group" id="nav-logo">
      <!-- Triangle icon representing Vercel but styled for media play/conversion -->
      <svg class="w-6 h-6 text-primary transition-transform duration-200 group-hover:scale-105" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M20 12L4 21V3L20 12Z" fill="currentColor" />
      </svg>
      <span class="text-xl font-bold tracking-tight text-primary">ytomp3</span>
      <span class="text-[10px] font-mono uppercase bg-canvas-soft-2 px-1.5 py-0.5 rounded-sm border border-hairline text-mute">v2.0</span>
    </a>

    <!-- Desktop Navigation Links -->
    <nav class="hidden md:flex items-center space-x-1" aria-label="Main Navigation">
      <a href="/" class={`text-sm px-3 py-1.5 rounded-full transition-colors duration-200 ${currentPath === '/' ? 'bg-canvas-soft-2 text-primary font-medium' : 'text-body hover:text-primary hover:bg-canvas-soft'}`}>
        Home
      </a>
      <a href="/faq" class={`text-sm px-3 py-1.5 rounded-full transition-colors duration-200 ${currentPath === '/faq' ? 'bg-canvas-soft-2 text-primary font-medium' : 'text-body hover:text-primary hover:bg-canvas-soft'}`}>
        FAQ
      </a>
      <a href="/#how-it-works" class="text-sm px-3 py-1.5 rounded-full text-body hover:text-primary hover:bg-canvas-soft transition-colors duration-200">
        How it Works
      </a>
    </nav>

    <!-- Desktop CTAs -->
    <div class="hidden md:flex items-center space-x-3">
      <a href="/add-on" class="text-sm font-medium text-body hover:text-primary transition-colors px-2 py-1">
        Browser Extension
      </a>
      <a 
        href="javascript:(function(){var url=window.location.href;if(url.indexOf('youtube.com/watch')!==-1){window.open('https://rytomp3.in/?url='+encodeURIComponent(url));}else{alert('Drag this to your bookmarks, then click it while watching a YouTube video!');}})();" 
        class="h-8 inline-flex items-center justify-center px-3 rounded-sm border border-hairline text-sm font-medium bg-canvas hover:bg-canvas-soft text-primary transition-colors shadow-level-2 select-none"
        title="Drag this button to your bookmarks bar"
        id="bookmarklet-btn"
      >
        Bookmarklet
      </a>
      
      <!-- Theme Toggle Button for Desktop -->
      <button 
        type="button" 
        id="theme-toggle" 
        class="w-8 h-8 rounded-sm hover:bg-canvas-soft transition-colors border border-transparent hover:border-hairline flex items-center justify-center text-body hover:text-primary cursor-pointer select-none"
        aria-label="Toggle theme"
      >
        <!-- Sun Icon (visible in dark mode) -->
        <svg class="w-4 h-4 hidden dark:block transition-transform duration-300 hover:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2"></path>
          <path d="M12 20v2"></path>
          <path d="m4.93 4.93 1.41 1.41"></path>
          <path d="m17.66 17.66 1.41 1.41"></path>
          <path d="M2 12h2"></path>
          <path d="M20 12h2"></path>
          <path d="m6.34 17.66-1.41 1.41"></path>
          <path d="m19.07 4.93-1.41 1.41"></path>
        </svg>
        <!-- Moon Icon (visible in light mode) -->
        <svg class="w-4 h-4 block dark:hidden transition-transform duration-300 hover:-rotate-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile CTAs / Menu Toggle -->
    <div class="flex items-center space-x-2 md:hidden">
      <!-- Theme Toggle Button for Mobile -->
      <button 
        type="button" 
        id="theme-toggle-mobile" 
        class="w-8 h-8 rounded-sm hover:bg-canvas-soft transition-colors border border-transparent hover:border-hairline flex items-center justify-center text-body hover:text-primary cursor-pointer select-none"
        aria-label="Toggle theme"
      >
        <!-- Sun Icon (visible in dark mode) -->
        <svg class="w-4 h-4 hidden dark:block transition-transform duration-300 hover:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2"></path>
          <path d="M12 20v2"></path>
          <path d="m4.93 4.93 1.41 1.41"></path>
          <path d="m17.66 17.66 1.41 1.41"></path>
          <path d="M2 12h2"></path>
          <path d="M20 12h2"></path>
          <path d="m6.34 17.66-1.41 1.41"></path>
          <path d="m19.07 4.93-1.41 1.41"></path>
        </svg>
        <!-- Moon Icon (visible in light mode) -->
        <svg class="w-4 h-4 block dark:hidden transition-transform duration-300 hover:-rotate-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
        </svg>
      </button>

      <!-- Mobile Menu Button -->
      <button 
        type="button" 
        class="flex flex-col justify-center items-center w-8 h-8 rounded-sm hover:bg-canvas-soft transition-colors border border-transparent hover:border-hairline" 
        id="mobile-menu-toggle"
        aria-label="Toggle menu"
      >
        <span class="w-5 h-0.5 bg-primary transition-transform duration-200 mb-1" id="line1"></span>
        <span class="w-5 h-0.5 bg-primary transition-opacity duration-200 mb-1" id="line2"></span>
        <span class="w-5 h-0.5 bg-primary transition-transform duration-200" id="line3"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Drawer Menu -->
  <div 
    class="md:hidden fixed top-[64px] left-0 w-full bg-canvas border-b border-hairline py-6 px-6 transform translate-y-[-120%] opacity-0 pointer-events-none transition-all duration-300 ease-in-out z-40 shadow-level-4" 
    id="mobile-drawer"
  >
    <nav class="flex flex-col space-y-4 mb-6">
      <a href="/" class={`text-base font-medium py-2 border-b border-hairline-strong/10 ${currentPath === '/' ? 'text-primary' : 'text-body'}`}>
        Home
      </a>
      <a href="/faq" class={`text-base font-medium py-2 border-b border-hairline-strong/10 ${currentPath === '/faq' ? 'text-primary' : 'text-body'}`}>
        FAQ
      </a>
      <a href="/#how-it-works" class="text-base font-medium py-2 border-b border-hairline-strong/10 text-body">
        How it Works
      </a>
      <a href="/add-on" class="text-base font-medium py-2 border-b border-hairline-strong/10 text-body">
        Browser Extension
      </a>
    </nav>
    <a 
      href="javascript:(function(){var url=window.location.href;if(url.indexOf('youtube.com/watch')!==-1){window.open('https://rytomp3.in/?url='+encodeURIComponent(url));}else{alert('Drag this to your bookmarks, then click it while watching a YouTube video!');}})();" 
      class="w-full h-10 flex items-center justify-center rounded-sm border border-hairline bg-canvas hover:bg-canvas-soft text-primary font-medium text-sm transition-colors shadow-level-2"
    >
      Drag Bookmarklet
    </a>
  </div>
</header>

<script>
  const toggleBtn = document.getElementById('mobile-menu-toggle');
  const drawer = document.getElementById('mobile-drawer');
  const line1 = document.getElementById('line1');
  const line2 = document.getElementById('line2');
  const line3 = document.getElementById('line3');

  let isOpen = false;

  toggleBtn?.addEventListener('click', () => {
    isOpen = !isOpen;
    if (isOpen) {
      // Open drawer
      drawer?.classList.remove('translate-y-[-120%]', 'opacity-0', 'pointer-events-none');
      drawer?.classList.add('translate-y-0', 'opacity-100');
      // Animate hamburger to X
      line1?.classList.add('rotate-45', 'translate-y-[6px]');
      line2?.classList.add('opacity-0');
      line3?.classList.add('-rotate-45', '-translate-y-[6px]');
    } else {
      // Close drawer
      drawer?.classList.add('translate-y-[-120%]', 'opacity-0', 'pointer-events-none');
      drawer?.classList.remove('translate-y-0', 'opacity-100');
      // Animate X to hamburger
      line1?.classList.remove('rotate-45', 'translate-y-[6px]');
      line2?.classList.remove('opacity-0');
      line3?.classList.remove('-rotate-45', '-translate-y-[6px]');
    }
  });

  // Close menu on navigation click (for hash links)
  const links = drawer?.querySelectorAll('a');
  links?.forEach(link => {
    link.addEventListener('click', () => {
      isOpen = false;
      drawer?.classList.add('translate-y-[-120%]', 'opacity-0', 'pointer-events-none');
      drawer?.classList.remove('translate-y-0', 'opacity-100');
      line1?.classList.remove('rotate-45', 'translate-y-[6px]');
      line2?.classList.remove('opacity-0');
      line3?.classList.remove('-rotate-45', '-translate-y-[6px]');
    });
  });

  // Theme Toggle Event Listeners
  const themeToggles = document.querySelectorAll('#theme-toggle, #theme-toggle-mobile');
  themeToggles.forEach(toggle => {
    toggle.addEventListener('click', () => {
      const isDark = document.documentElement.classList.contains('dark');
      if (isDark) {
        document.documentElement.classList.remove('dark');
        localStorage.setItem('theme', 'light');
      } else {
        document.documentElement.classList.add('dark');
        localStorage.setItem('theme', 'dark');
      }
    });
  });
</script>
