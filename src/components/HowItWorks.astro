---
---
<section class="py-20 bg-canvas border-b border-hairline" id="how-it-works" aria-label="How it Works Instructions">
  <div class="max-w-[1200px] mx-auto px-6">
    <!-- Header -->
    <div class="text-center max-w-[700px] mx-auto mb-16">
      <p class="text-xs font-mono uppercase tracking-wider text-[#7928ca] mb-3">Workflow Tutorial</p>
      <h2 class="display-lg text-primary text-3xl md:text-4xl mb-4">
        Convert videos in three steps.
      </h2>
      <p class="text-base text-body leading-relaxed">
        Simple and direct, our tool is optimized to deliver media in the absolute minimum amount of clicks.
      </p>
    </div>

    <!-- Steps Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 relative">
      <!-- Decorative connector lines (desktop only) -->
      <div class="hidden md:block absolute top-[28px] left-[15%] right-[15%] h-[1px] bg-hairline z-0"></div>

      <!-- Step 1 -->
      <div class="flex flex-col items-center text-center relative z-10 space-y-4">
        <div class="w-14 h-14 rounded-full bg-primary text-on-primary font-mono font-semibold text-lg flex items-center justify-center border-4 border-canvas shadow-level-2 select-none">
          1
        </div>
        <div class="space-y-2">
          <h3 class="text-lg font-semibold text-primary">Copy video link.</h3>
          <p class="text-sm text-body leading-relaxed max-w-[280px] mx-auto">
            Navigate to YouTube, copy the address from your browser bar, or click share and copy.
          </p>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="flex flex-col items-center text-center relative z-10 space-y-4">
        <div class="w-14 h-14 rounded-full bg-primary text-on-primary font-mono font-semibold text-lg flex items-center justify-center border-4 border-canvas shadow-level-2 select-none">
          2
        </div>
        <div class="space-y-2">
          <h3 class="text-lg font-semibold text-primary">Paste & customize.</h3>
          <p class="text-sm text-body leading-relaxed max-w-[280px] mx-auto">
            Paste the link into the converter input, choose your format (MP3 or MP4) and select quality.
          </p>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="flex flex-col items-center text-center relative z-10 space-y-4">
        <div class="w-14 h-14 rounded-full bg-primary text-on-primary font-mono font-semibold text-lg flex items-center justify-center border-4 border-canvas shadow-level-2 select-none">
          3
        </div>
        <div class="space-y-2">
          <h3 class="text-lg font-semibold text-primary">Save to device.</h3>
          <p class="text-sm text-body leading-relaxed max-w-[280px] mx-auto">
            Wait a few seconds for the cloud conversion to complete, then click the download button.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
