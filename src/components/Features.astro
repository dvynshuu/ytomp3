---
---
<section class="py-20 bg-canvas-soft border-b border-hairline" aria-label="ytomp3 Features">
  <div class="max-w-[1200px] mx-auto px-6">
    <!-- Header -->
    <div class="text-center max-w-[700px] mx-auto mb-16">
      <p class="text-xs font-mono uppercase tracking-wider text-[#007cf0] mb-3">Engineered for Simplicity</p>
      <h2 class="display-lg text-primary text-3xl md:text-4xl mb-4">
        Optimized audio and video exports.
      </h2>
      <p class="text-base text-body leading-relaxed">
        We handle the heavy lifting of extracting and converting media streams directly on our cloud architecture, sending high-quality files straight to your device.
      </p>
    </div>

    <!-- Features Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Card 1 -->
      <div class="bg-canvas border border-hairline rounded-md p-6 shadow-level-3 hover:shadow-level-4 transition-shadow duration-200">
        <div class="w-10 h-10 rounded-sm bg-canvas-soft-2 border border-hairline flex items-center justify-center text-primary mb-5 shadow-level-1">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <h3 class="display-sm text-primary mb-2">Instant Downloads.</h3>
        <p class="text-sm text-body leading-relaxed">
          Skip queues and loading frames. Our backend is tuned to stream and convert YouTube audio in real-time, providing immediate file links.
        </p>
      </div>

      <!-- Card 2 -->
      <div class="bg-canvas border border-hairline rounded-md p-6 shadow-level-3 hover:shadow-level-4 transition-shadow duration-200">
        <div class="w-10 h-10 rounded-sm bg-canvas-soft-2 border border-hairline flex items-center justify-center text-primary mb-5 shadow-level-1">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </div>
        <h3 class="display-sm text-primary mb-2">No Sign-up Required.</h3>
        <p class="text-sm text-body leading-relaxed">
          We don't collect emails, log credentials, or force logins. Your privacy is paramount. Open the site, paste your link, and get your file.
        </p>
      </div>

      <!-- Card 3 -->
      <div class="bg-canvas border border-hairline rounded-md p-6 shadow-level-3 hover:shadow-level-4 transition-shadow duration-200">
        <div class="w-10 h-10 rounded-sm bg-canvas-soft-2 border border-hairline flex items-center justify-center text-primary mb-5 shadow-level-1">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
          </svg>
        </div>
        <h3 class="display-sm text-primary mb-2">Lossless Bitrates.</h3>
        <p class="text-sm text-body leading-relaxed">
          Select standard 192kbps for quick downloads, or select ultra-high 320kbps MP3 for true high-fidelity listening. Supports full 1080p MP4.
        </p>
      </div>
    </div>
  </div>
</section>
