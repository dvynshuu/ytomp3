---
---
<section class="py-20 dark-mesh-gradient-bg border-b border-white/10 text-on-primary relative overflow-hidden" aria-label="Supported Media Formats">
  <!-- Mesh decorative atmospheric glow -->
  <div class="absolute inset-0 pointer-events-none opacity-20 select-none">
    <div class="absolute bottom-0 right-1/4 w-[600px] h-[400px] bg-gradient-to-t from-[#ff0080]/10 via-[#7928ca]/5 to-transparent rounded-full blur-[80px]"></div>
  </div>

  <div class="max-w-[1200px] mx-auto px-6 relative z-10">
    <!-- Header -->
    <div class="max-w-[700px] mb-16">
      <p class="text-xs font-mono uppercase tracking-wider text-cyan-soft mb-3">Codec & Container Support</p>
      <h2 class="display-lg text-white text-3xl md:text-4xl mb-4">
        Multi-tier quality streams.
      </h2>
      <p class="text-base text-mute leading-relaxed max-w-[600px]">
        Select the target compression bitrate or display resolution. Our cloud media wrappers package your downloads utilizing standard industry codecs for absolute compatibility.
      </p>
    </div>

    <!-- Formats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- MP3 Details Card -->
      <div class="bg-[#121212]/90 border border-white/10 rounded-md p-8 shadow-level-4 flex flex-col justify-between">
        <div>
          <div class="flex items-center justify-between mb-6">
            <span class="text-xs font-mono text-cyan uppercase tracking-wider">Audio Format</span>
            <span class="px-2.5 py-0.5 rounded-full text-[10px] font-semibold bg-cyan/10 text-cyan border border-cyan/20">MPEG-3</span>
          </div>
          <h3 class="display-md text-white mb-3">MP3 Audio Files.</h3>
          <p class="text-sm text-mute leading-relaxed mb-6">
            Best for music players, smartphones, and offline listening. Extracted as a pure stereo audio track.
          </p>

          <!-- Specifications -->
          <ul class="space-y-3 mb-8">
            <li class="flex items-center text-sm text-gray-300">
              <svg class="w-4 h-4 text-cyan mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Bitrates: <strong class="text-white font-medium">128kbps, 192kbps, 256kbps, 320kbps</strong></span>
            </li>
            <li class="flex items-center text-sm text-gray-300">
              <svg class="w-4 h-4 text-cyan mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Duration Limit: <strong class="text-white font-medium">Up to 240 minutes</strong> (4 hours)</span>
            </li>
            <li class="flex items-center text-sm text-gray-300">
              <svg class="w-4 h-4 text-cyan mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Stereo Configuration: <strong class="text-white font-medium">Dual-channel Joint Stereo</strong></span>
            </li>
          </ul>
        </div>

        <div class="pt-6 border-t border-white/5 flex flex-wrap gap-2">
          <span class="px-2 py-1 rounded bg-white/5 border border-white/10 text-xs text-mute font-mono">.mp3</span>
          <span class="px-2 py-1 rounded bg-white/5 border border-white/10 text-xs text-mute font-mono">ID3v2 Tags</span>
          <span class="px-2 py-1 rounded bg-white/5 border border-white/10 text-xs text-mute font-mono">CBR</span>
        </div>
      </div>

      <!-- MP4 Details Card -->
      <div class="bg-[#121212]/90 border border-white/10 rounded-md p-8 shadow-level-4 flex flex-col justify-between">
        <div>
          <div class="flex items-center justify-between mb-6">
            <span class="text-xs font-mono text-[#ff0080] uppercase tracking-wider">Video Format</span>
            <span class="px-2.5 py-0.5 rounded-full text-[10px] font-semibold bg-[#ff0080]/10 text-[#ff0080] border border-[#ff0080]/20">MPEG-4</span>
          </div>
          <h3 class="display-md text-white mb-3">MP4 Video Files.</h3>
          <p class="text-sm text-mute leading-relaxed mb-6">
            Best for playing video clips offline on tablets, laptops, TVs, and mobile screens.
          </p>

          <!-- Specifications -->
          <ul class="space-y-3 mb-8">
            <li class="flex items-center text-sm text-gray-300">
              <svg class="w-4 h-4 text-[#ff0080] mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Resolutions: <strong class="text-white font-medium">360p, 480p, 720p (HD), 1080p (FHD)</strong></span>
            </li>
            <li class="flex items-center text-sm text-gray-300">
              <svg class="w-4 h-4 text-[#ff0080] mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Duration Limit: <strong class="text-white font-medium">Up to 60 minutes</strong> (1 hour)</span>
            </li>
            <li class="flex items-center text-sm text-gray-300">
              <svg class="w-4 h-4 text-[#ff0080] mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Video Codec: <strong class="text-white font-medium">H.264 / AVC</strong> with AAC audio</span>
            </li>
          </ul>
        </div>

        <div class="pt-6 border-t border-white/5 flex flex-wrap gap-2">
          <span class="px-2 py-1 rounded bg-white/5 border border-white/10 text-xs text-mute font-mono">.mp4</span>
          <span class="px-2 py-1 rounded bg-white/5 border border-white/10 text-xs text-mute font-mono">Progressive</span>
          <span class="px-2 py-1 rounded bg-white/5 border border-white/10 text-xs text-mute font-mono">30 FPS</span>
        </div>
      </div>
    </div>
  </div>
</section>
